<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>NSCameraUsageDescription</key>
	<string>We need camera access to take photos</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>We need photo library access to select photos</string>
	<key>SKPaymentTransactionObserver</key>
	<true/>
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>https</string>
		<string>http</string>
		<string>tez</string>
		<string>gpay</string>
		<string>phonepe</string>
		<string>paytmmp</string>
		<string>paytm</string>
		<string>bhim</string>
		<string>upi</string>
		<string>razorpay</string>
	</array>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Devalay</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>devalay</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	

<key>CFBundleURLTypes</key>
<array>
    <dict>
        <key>CFBundleTypeRole</key>
        <string>Editor</string>
        <key>CFBundleURLName</key>
        <string>com.ios.devalay</string>
        <key>CFBundleURLSchemes</key>
        <array>
            <string>devalay</string>
        </array>
    </dict>
</array>

<key>FlutterDeepLinkingEnabled</key>
<true/>
	
	<key>LSRequiresIPhoneOS</key>
	<true/>
	
	<!-- NOTE: Associated Domains should be in Runner.entitlements, NOT here -->
	
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
	</dict>
	
	<key>NSCameraUsageDescription</key>
	<string>Devalay needs camera access to capture and upload photos of temples, religious events, puja ceremonies, and deity decorations.</string>
	
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>Devalay needs location access to provide you with timely updates about nearby temple events and religious activities.</string>
	
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Devalay needs your location to show nearby temples, religious events, and pujas happening in your area.</string>
	
	<key>NSMicrophoneUsageDescription</key>
	<string>Devalay needs microphone access to record videos with audio of religious ceremonies, bhajans, and temple events.</string>
	
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Devalay needs permission to save downloaded images, event posters, and temple photos to your device.</string>
	
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Devalay needs access to your photo library to upload and share temple photos, puja ceremonies, and religious event pictures with the community.</string>
	
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
		<string>fetch</string>
	</array>
	
	<key>UIDeviceFamily</key>
	<array>
		<integer>1</integer>
	</array>
	
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	
	<key>UIRequiresFullScreen</key>
	<true/>
	
	<key>UIStatusBarStyle</key>
	<string>UIStatusBarStyleDefault</string>
	
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	
	<!-- Explicitly exclude iPad support -->
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
	</array>
</dict>
</plist>